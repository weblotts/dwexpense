    "autoprefixer": "^10.4.19",
    "concurrently": "^9.0.1",
    "nx": "19.8.4",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
